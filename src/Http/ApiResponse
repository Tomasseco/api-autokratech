<?php

require __DIR__ . '/../Error/ErrorCatalog.php'; 

final class ApiResponse {
    
    // Success response, with an optional HTTP status code (default: 200)
    public static function ok(array $data = [], int $status = 200): void {
        http_response_code($status);
        echo json_encode(['ok' => true, 'data' => $data], JSON_UNESCAPED_UNICODE);
        exit;
    }

    // Error response, using an error code defined in the ErrorCatalog
    public static function error(string $code, array $datails = []): void {
        $error = ErrorCatalog::get($code);
        http_response_code($error['status']);
        echo json_encode([
            'ok' => false,
            'error' => [
                'code' => $code,
                'message' => $error['message'],
                'details' => (object)$datails,
            ],
        ], JSON_UNESCAPED_UNICODE);
        exit;       
    }
}
